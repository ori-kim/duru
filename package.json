{
  "name": "clip",
  "version": "0.2617.87",
  "type": "module",
  "workspaces": ["apps/*", "packages/*", "extensions/*"],
  "scripts": {
    "dev": "bun apps/clip/src/main.ts",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "gen-core-types": "bun scripts/gen-core-types.ts",
    "build:darwin-arm64": "bun run gen-core-types && bun build --compile --target=bun-darwin-arm64 ./apps/clip/src/main.ts --outfile=dist/clip-darwin-arm64",
    "build:darwin-x64": "bun run gen-core-types && bun build --compile --target=bun-darwin-x64   ./apps/clip/src/main.ts --outfile=dist/clip-darwin-x64",
    "build": "bun run build:darwin-arm64 && bun run build:darwin-x64"
  },
  "dependencies": {
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest"
  }
}
