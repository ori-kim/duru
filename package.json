{
  "name": "clip",
  "version": "0.6.0",
  "type": "module",
  "bin": {
    "clip": "./clip"
  },
  "scripts": {
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 ./src/clip.ts --outfile=dist/clip-darwin-arm64",
    "build:darwin-x64":   "bun build --compile --target=bun-darwin-x64   ./src/clip.ts --outfile=dist/clip-darwin-x64",
    "build": "bun run build:darwin-arm64 && bun run build:darwin-x64"
  },
  "dependencies": {
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest"
  }
}
