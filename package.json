{
  "name": "clip-framework",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "workspaces": ["apps/*", "core/*", "packages/*"],
  "scripts": {
    "dev": "bun apps/clip-cli/src/main.ts",
    "check": "bun run typecheck && bun run lint && bun run test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest"
  }
}
