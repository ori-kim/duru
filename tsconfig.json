{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "paths": {
      "@clip/kit": ["./core/clip-kit/src/index.ts"],
      "@clip/env": ["./packages/env/src/index.ts"],
      "@clip/file-store": ["./packages/file-store/src/index.ts"],
      "@clip/cli-gateway": ["./packages/cli-gateway/src/index.ts"],
      "@clip/input-validation": ["./packages/input-validation/src/index.ts"],
      "@clip/renderer-json": ["./packages/renderer-json/src/index.ts"],
      "@clip/renderer-text": ["./packages/renderer-text/src/index.ts"],
      "@clip/virtual-plugins": ["./packages/virtual-plugins/src/index.ts"]
    }
  },
  "include": ["apps/**/*.ts", "core/**/*.ts", "packages/**/*.ts"],
  "exclude": ["node_modules", "dist", ".agents", ".claude", ".clip-test"]
}
