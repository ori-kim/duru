{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "paths": {
      "@clip/core": ["./core/framework/src/index.ts"],
      "@clip/input-zod": ["./packages/input-zod/src/index.ts"],
      "@clip/renderer-json": ["./packages/renderer-json/src/index.ts"],
      "@clip/renderer-text": ["./packages/renderer-text/src/index.ts"]
    }
  },
  "include": ["apps/**/*.ts", "core/**/*.ts", "packages/**/*.ts"],
  "exclude": ["node_modules", "dist", ".agents", ".claude", ".clip-test"]
}
