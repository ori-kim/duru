{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "paths": {
      "@clip/core": ["./packages/core/src/index.ts"],
      "@clip/auth": ["./packages/auth/src/index.ts"],
      "@clip/protocol-mcp": ["./extensions/protocol-mcp/src/index.ts"],
      "@clip/protocol-api": ["./extensions/protocol-api/src/index.ts"],
      "@clip/protocol-graphql": ["./extensions/protocol-graphql/src/index.ts"],
      "@clip/protocol-grpc": ["./extensions/protocol-grpc/src/index.ts"],
      "@clip/protocol-cli": ["./extensions/protocol-cli/src/index.ts"],
      "@clip/protocol-script": ["./extensions/protocol-script/src/index.ts"]
    }
  }
}
